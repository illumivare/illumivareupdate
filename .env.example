# Port number for the application server
PORT=3000

# MongoDB Atlas Connection URI
# Example: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=

# Gemini API Key for AI features (Note: Use GEMINI_API_KEY as requested)
# Retrieve your key from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=

# Environment name (development, production)
NODE_ENV=development
